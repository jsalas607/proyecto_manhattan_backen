# Base de datos (usada por la API). El host "db" es el nombre del servicio en docker-compose.
DATABASE_URL=postgresql+asyncpg://manhattan:manhattan@db:5432/manhattan

# Credenciales con que docker-compose inicializa el contenedor de Postgres
POSTGRES_USER=manhattan
POSTGRES_PASSWORD=manhattan
POSTGRES_DB=manhattan

# Seguridad / JWT  -> cambia JWT_SECRET en producción por algo aleatorio y largo
JWT_SECRET=cambia-esto-en-produccion
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Admin global que se crea automáticamente al arrancar si la BD no tiene usuarios
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Subida de imágenes
UPLOADS_DIR=uploads
MAX_UPLOAD_MB=5

# CORS (separar orígenes por comas, o "*" para permitir todo en desarrollo)
CORS_ORIGINS=*
